-- ///////////////////////////////////////////////
-- // ESP FUNCTIONS (ระบบมองทะลุ)
-- ///////////////////////////////////////////////

local function UpdateESP(player)
    if player == LocalPlayer then return end
    
    if not player.Character then return end
    local char = player.Character
    local root = char:FindFirstChild("HumanoidRootPart")
    
    if not root then return end

    local hl = char:FindFirstChild("ESPHighlight")
    if not hl then
        hl = Instance.new("Highlight")
        hl.Name = "ESPHighlight"
        hl.Adornee = char
        hl.Parent = char
    end
    
    hl.FillTransparency = 1 
    hl.OutlineTransparency = 0 
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop 
    hl.Enabled = _G.ESPEnabled

    if _G.TeamCheck and player.Team == LocalPlayer.Team then
        hl.OutlineColor = Color3.fromRGB(0, 255, 0) 
    else
        hl.OutlineColor = _G.ESPGlowColor 
    end
    
    local head = char:FindFirstChild("Head")
    if head and head:FindFirstChild("ESPBillboard") then
        head.ESPBillboard:Destroy()
    end
end

task.spawn(function()
    while true do
        task.wait(_G.ESPRefreshRate)
        if _G.ESPEnabled then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer then
                    pcall(function() 
                        UpdateESP(p)
                    end)
                end
            end
        end
    end
end)

-- ///////////////////////////////////////////////
-- // AIMBOT FUNCTIONS
-- ///////////////////////////////////////////////

local function GetClosestPlayer()
    local MaximumDistance = _G.CircleRadius
    local Target = nil
    -- ใช้จุดกึ่งกลางจอเป๊ะๆ ในการหาเป้า (แก้ปัญหาเมาส์ไม่ตรงเป้า)
    local CenterPosition = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, v in ipairs(Players:GetPlayers()) do
        if v ~= LocalPlayer then
            if _G.TeamCheck and v.Team == LocalPlayer.Team then
                continue
            end

            if v.Character and v.Character:FindFirstChild(_G.AimPart) and v.Character:FindFirstChild("Humanoid") then
                if v.Character.Humanoid.Health > 0 then
                    -- ดึงตำแหน่งของส่วนที่เล็ง
                    local targetPart = v.Character[_G.AimPart]
                    -- เปลี่ยนใช้ WorldToViewportPoint ทำให้คำนวณได้ตรงกับจุดบนจอ 100% ไม่มีบัคเหลื่อม 36 pixel
                    local ScreenPoint, OnScreen = Camera:WorldToViewportPoint(targetPart.Position)
                    
                    -- เช็ค 1: ห้ามล็อคตัวที่อยู่นอกจอ
                    if OnScreen then
                        -- วัดระยะห่างจากจุดแดงกลางจอ
                        local VectorDistance = (Vector2.new(CenterPosition.X, CenterPosition.Y) - Vector2.new(ScreenPoint.X, ScreenPoint.Y)).Magnitude
                        
                        -- เช็ค 2: ต้องอยู่ในวง (<= _G.CircleRadius) 
                        -- เช็ค 3: หาตัวที่ใกล้จุดกลางจอที่สุด
                        if VectorDistance <= MaximumDistance then
                            Target = v
                            MaximumDistance = VectorDistance
                        end
                    end
                end
            end
        end
    end

    return Target
end

-- ///////////////////////////////////////////////
-- // INPUT HANDLING (รับค่าปุ่มกด)
-- ///////////////////////////////////////////////

UserInputService.InputBegan:Connect(function(Input, gameProcessed)
    -- แก้ไข: ใช้ GetFocusedTextBox แทน gameProcessed เพื่อป้องกันบัคปุ่มทับกับระบบเกม
    -- จะไม่ทำงานแค่ตอนที่เรากำลังพิมพ์ช่องแชทเท่านั้น
    if UserInputService:GetFocusedTextBox() then return end 
    
    -- ปุ่มเปิด/ปิด Aimbot (J)
    if Input.KeyCode == _G.AimbotToggleKey then
        AimbotOn = not AimbotOn
        
        if AimbotOn then
            _G.CircleColor = Color3.fromRGB(0, 255, 0)
            SendLog("Aimbot: ON", Color3.fromRGB(0, 255, 0))
        else
            _G.CircleColor = Color3.fromRGB(255, 255, 255)
            SendLog("Aimbot: OFF", Color3.fromRGB(255, 0, 0))
        end
    end

    -- ปุ่มระดับความเร็ว (P)
    if Input.KeyCode == _G.SpeedToggleKey then
        SpeedState = SpeedState + 1
        if SpeedState > 3 then
            SpeedState = 0 -- วนกลับมาปิด
        end

        local currentHum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
        
        if SpeedState == 0 then
            SendLog("Speed: OFF (Normal)", Color3.fromRGB(255, 0, 0))
            if currentHum then currentHum.WalkSpeed = DefaultSpeed end
        elseif SpeedState == 1 then
            SendLog("Speed: Level 1 (" .. _G.SpeedLevel1 .. ")", Color3.fromRGB(0, 255, 255))
            if currentHum then currentHum.WalkSpeed = _G.SpeedLevel1 end
        elseif SpeedState == 2 then
            SendLog("Speed: Level 2 (" .. _G.SpeedLevel2 .. ")", Color3.fromRGB(0, 150, 255))
            if currentHum then currentHum.WalkSpeed = _G.SpeedLevel2 end
        elseif SpeedState == 3 then
            SendLog("Speed: Level 3 (" .. _G.SpeedLevel3 .. ")", Color3.fromRGB(150, 0, 255))
            if currentHum then currentHum.WalkSpeed = _G.SpeedLevel3 end
        end
    end
end)

