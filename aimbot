SendLog("Script Loaded! Press J for Aimbot, P for Speed.", Color3.fromRGB(0, 255, 255))

RunService.RenderStepped:Connect(function()
    -- 0. อัพเดท Camera FOV
    if _G.EnableCameraFOV then
        Camera.FieldOfView = _G.CameraFOVValue
    end

    -- 1. อัพเดทตำแหน่งวงกลม และจุดแดงกลางจอ ให้อยู่กลางจอเสมอ
    local ScreenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    FOVCircle.Position = ScreenCenter
    FOVCircle.Radius = _G.CircleRadius
    FOVCircle.Color = _G.CircleColor
    FOVCircle.Visible = _G.CircleVisible
    FOVCircle.Thickness = _G.CircleThickness
    FOVCircle.Transparency = _G.CircleTransparency

    CenterDot.Position = ScreenCenter
    CenterDot.Radius = _G.CenterDotSize
    CenterDot.Color = _G.CenterDotColor
    CenterDot.Visible = _G.CenterDotVisible

    -- 2. รันระบบ ESP
    if _G.ESPEnabled then
        for _, p in ipairs(Players:GetPlayers()) do
             if p ~= LocalPlayer and p.Character then
                UpdateESP(p) 
             end
        end
    end

    -- 3. ล็อคความเร็ว (Speed Hack Enforcement)
    -- ป้องกันเกมแอบเปลี่ยนความเร็วกลับ
    if SpeedState > 0 and LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then
            if SpeedState == 1 then
                hum.WalkSpeed = _G.SpeedLevel1
            elseif SpeedState == 2 then
                hum.WalkSpeed = _G.SpeedLevel2
            elseif SpeedState == 3 then
                hum.WalkSpeed = _G.SpeedLevel3
            end
        end
    end

    -- 4. Aimbot Logic
    if AimbotOn then
        local target = GetClosestPlayer()
        if target and target.Character and target.Character:FindFirstChild(_G.AimPart) then
            local targetPos = target.Character[_G.AimPart].Position
            local currentCF = Camera.CFrame
            local targetCF = CFrame.new(currentCF.Position, targetPos)
            
            local alpha = math.clamp(_G.LockPercent / 100, 0, 1) * 0.5 
            Camera.CFrame = currentCF:Lerp(targetCF, alpha)
        end
    end
end)
