local function BuildPlayerOptions()
    local opts = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then table.insert(opts, p.Name) end
    end
    if #opts == 0 then opts = {"(ยังไม่มีผู้เล่น)"} end
    return opts
end

