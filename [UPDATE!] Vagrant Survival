-- ===================== Teleport Core ===================== --
--[[  V8 Tween:
      step  = 5 studs
      speed = 80 studs/s  (tweenTime = 5/80 = 0.0625s)
      pause = 0.05s ระหว่าง step
      ลอย +3 studs เหนือพื้นตลอด (ไม่ตาย)
      ถึงเป้า → บินขึ้น 10 studs → ลงช้าๆ 3.5 studs ]]
local function StartMicroTween(targetPart, targetName, isBag)
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local hrp = character.HumanoidRootPart

    isTweening = false
    if currentTween then currentTween:Cancel() end
    task.wait(0.05)
    isTweening = true

    task.spawn(function()
        game.StarterGui:SetCore("SendNotification", {
            Title = "Teleporting", Text = "→ " .. targetName, Duration = 2
        })

        local bv = hrp:FindFirstChild("TeleportBV")
        if not bv then
            bv            = Instance.new("BodyVelocity")
            bv.Name       = "TeleportBV"
            bv.MaxForce   = Vector3.new(1e5, 1e5, 1e5)
            bv.Velocity   = Vector3.zero
            bv.Parent     = hrp
        end

        local STEP  = 5
        local SPEED = 50
        local PAUSE = 0.10

        while isTweening do
            if not targetPart or not targetPart.Parent then
                isTweening = false
                game.StarterGui:SetCore("SendNotification", {
                    Title = "Target Lost", Text = "เป้าหายไปแล้ว", Duration = 2
                })
                break
            end

            local curPos    = hrp.Position
            local targetPos = targetPart.Position + Vector3.new(0, 1, 0)
            local dist      = (curPos - targetPos).Magnitude

            if dist <= 6 then
                -- บินขึ้น
                local upT = TweenService:Create(hrp,
                    TweenInfo.new(0.3, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
                    {CFrame = CFrame.new(targetPart.Position + Vector3.new(0, 10, 0))})
                upT:Play(); upT.Completed:Wait()
                task.wait(0.05)
                -- ลงช้าๆ
                local downT = TweenService:Create(hrp,
                    TweenInfo.new(0.4, Enum.EasingStyle.Sine, Enum.EasingDirection.In),
                    {CFrame = CFrame.new(targetPart.Position + Vector3.new(0, 3.5, 0))})
                downT:Play(); downT.Completed:Wait()

                isTweening = false
                if isBag and targetPart then visitedBags[targetPart] = true end
                game.StarterGui:SetCore("SendNotification", {
                    Title = "Arrived ✓", Text = "ถึง " .. targetName, Duration = 2
                })
                break
            end

            local step    = math.min(STEP, dist)
            local dir     = (targetPos - curPos).Unit
            local nextPos = curPos + dir * step

            -- Raycast → ลอยพื้น +3 studs
            local rp = RaycastParams.new()
            rp.FilterType = Enum.RaycastFilterType.Exclude
            local ign = {character}
            local spF = Workspace:FindFirstChild("Spawned")
            if spF and spF:FindFirstChild("Destructibles") then
                table.insert(ign, spF.Destructibles)
            end
            rp.FilterDescendantsInstances = ign
            rp.RespectCanCollide = true

            local ray = workspace:Raycast(
                Vector3.new(nextPos.X, curPos.Y + 50, nextPos.Z),
                Vector3.new(0, -100, 0), rp)

            if ray then
                nextPos = Vector3.new(nextPos.X, ray.Position.Y + 3, nextPos.Z)
            else
                nextPos = Vector3.new(nextPos.X, curPos.Y + 3, nextPos.Z)
            end

            currentTween = TweenService:Create(hrp,
                TweenInfo.new(step / SPEED, Enum.EasingStyle.Linear),
                {CFrame = CFrame.new(nextPos)})
            currentTween:Play()
            currentTween.Completed:Wait()

            if isTweening then task.wait(PAUSE) end
        end

        if hrp:FindFirstChild("TeleportBV") then hrp.TeleportBV:Destroy() end
    end)
end

-- หากระเป๋าใกล้สุด (ข้าม visited)
local function TweenToClosestItem(itemName)
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local hrp = character.HumanoidRootPart

    local spF = Workspace:FindFirstChild("Spawned")
    if not spF then return end
    local ignF = spF:FindFirstChild("MouseIgnoreFolder")
    if not ignF then return end
    local lootF = ignF:FindFirstChild("Loot")
    if not lootF then return end

    local closest, minDist = nil, math.huge
    for _, item in pairs(lootF:GetChildren()) do
        if item.Name == itemName then
            local part = item:IsA("BasePart") and item
                or (item:IsA("Model") and (item:FindFirstChildWhichIsA("BasePart") or item.PrimaryPart))
            if part and not visitedBags[part] then
                local d = (hrp.Position - part.Position).Magnitude
                if d < minDist then minDist = d; closest = part end
            end
        end
    end

    if closest then
        StartMicroTween(closest, itemName, true)
    else
        game.StarterGui:SetCore("SendNotification", {
            Title = "Not Found",
            Text  = "ไม่พบ " .. itemName .. " (กด Reset ถ้าต้องการไปซ้ำ)",
            Duration = 3
        })
    end
end

