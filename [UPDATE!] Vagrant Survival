RunService.Heartbeat:Connect(function()
    -- No Clip (bypass เด้ง + ป้องกันทะลุใต้แมพ)
    if NO_CLIP then
        pcall(function()
            local char = player.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChild("Humanoid")

            -- ปิด collision ทุก part
            for _, p in pairs(char:GetDescendants()) do
                if p:IsA("BasePart") then
                    p.CanCollide = false
                end
            end

            -- ป้องกันทะลุพื้น Terrain: raycast ลงมา ถ้าใกล้พื้นมากเกิน → ดัน Y ขึ้น
            if hrp then
                local rp = RaycastParams.new()
                rp.FilterType = Enum.RaycastFilterType.Include
                rp.FilterDescendantsInstances = {workspace.Terrain}
                local ray = workspace:Raycast(
                    hrp.Position + Vector3.new(0, 1, 0),
                    Vector3.new(0, -3.5, 0),
                    rp
                )
                if ray then
                    -- อยู่ใกล้ Terrain เกินไป → ดันขึ้นเล็กน้อยแทนการทะลุ
                    local safeY = ray.Position.Y + 3
                    if hrp.Position.Y < safeY then
                        hrp.CFrame = CFrame.new(hrp.Position.X, safeY, hrp.Position.Z)
                            * (hrp.CFrame - hrp.CFrame.Position)
                    end
                end
            end

            -- ยกเลิก Humanoid state ที่ทำให้เด้งถอยหลัง
            if hum then
                local state = hum:GetState()
                if state == Enum.HumanoidStateType.Freefall
                    or state == Enum.HumanoidStateType.Landed then
                    hum:ChangeState(Enum.HumanoidStateType.Running)
                end
            end
        end)
    end


    -- God Mode: คืน HP ทุก heartbeat (double protection)
    if GOD_MODE then
        pcall(function()
            local char = player.Character
            if char then
                local hum = char:FindFirstChild("Humanoid")
                if hum then
                    if hum.Health < hum.MaxHealth then
                        hum.Health = hum.MaxHealth
                    end
                    -- ป้องกัน death state
                    if hum:GetState() == Enum.HumanoidStateType.Dead then
                        hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                    end
                end
            end
        end)
    end

    -- Anti Fall (ตรวจใต้ Terrain ด้วย raycast จากบนลง + ตรวจตกแมพ)
    if ANTI_FALL then
        pcall(function()
            local char = player.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end

            local pos = hrp.Position

            -- หาพื้น Terrain จากด้านบนลง
            local rpTerrain = RaycastParams.new()
            rpTerrain.FilterType = Enum.RaycastFilterType.Include
            rpTerrain.FilterDescendantsInstances = {workspace.Terrain}
            local terrainRay = workspace:Raycast(
                Vector3.new(pos.X, pos.Y + 500, pos.Z),
                Vector3.new(0, -1500, 0),
                rpTerrain
            )
            local terrainSurfaceY = terrainRay and terrainRay.Position.Y or nil

            -- ตรวจว่า player อยู่ใต้พื้น Terrain หรือตกแมพ (Y < -50)
            local belowTerrain = terrainSurfaceY and (pos.Y < terrainSurfaceY - 0.5)
            local fallenOff    = pos.Y < -50

            if belowTerrain or fallenOff then
                -- หยุดความเร็วทันที
                hrp.AssemblyLinearVelocity = Vector3.zero

                -- หาตำแหน่งปลอดภัย: เหนือ Terrain + 5 studs
                local safeY
                if terrainSurfaceY then
                    safeY = terrainSurfaceY + 5
                else
                    -- ไม่เจอ Terrain → ใช้ raycast ทั่วไป
                    local rpAll = RaycastParams.new()
                    rpAll.FilterType = Enum.RaycastFilterType.Exclude
                    rpAll.FilterDescendantsInstances = {char}
                    local allRay = workspace:Raycast(
                        Vector3.new(pos.X, 500, pos.Z),
                        Vector3.new(0, -1000, 0),
                        rpAll
                    )
                    safeY = allRay and (allRay.Position.Y + 5) or 50
                end

                -- Tween ขึ้นไปยังตำแหน่งปลอดภัย
                local bv = hrp:FindFirstChild("TeleportBV")
                if not bv then
                    bv = Instance.new("BodyVelocity")
                    bv.Name     = "TeleportBV"
                    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
                    bv.Velocity = Vector3.zero
                    bv.Parent   = hrp
                end

                local rt = TweenService:Create(hrp,
                    TweenInfo.new(0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
                    {CFrame = CFrame.new(pos.X, safeY, pos.Z)})
                rt:Play()
                rt.Completed:Connect(function()
                    if hrp:FindFirstChild("TeleportBV") and not isTweening then
                        hrp.TeleportBV:Destroy()
                    end
                end)
            end
        end)
    end

end)

