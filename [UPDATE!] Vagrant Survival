                            elseif n == "Pipe"           then c = Color3.fromRGB(139, 69,  19)
                            elseif n == "Pot Helmet"     then c = Color3.fromRGB(192, 192, 192)
                            end
                            ApplyESP(item, n, c)
                        end
                        task.wait()  -- yield ต่อ item เพื่อไม่แล็คเมื่อ item เยอะ
                    end
                end
            end

            local destF = spF:FindFirstChild("Destructibles")
            if destF then
                for _, item in pairs(destF:GetChildren()) do
                    if (item:IsA("Model") or item:IsA("BasePart")) and item.Name == "Military Crate" then
                        ApplyESP(item, item.Name, Color3.fromRGB(50, 255, 50))
                    end
                    task.wait()
                end
            end
        end)
    end
end)
