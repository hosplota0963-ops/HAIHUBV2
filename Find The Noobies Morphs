-- ฟังก์ชันดึงพิกัด (CFrame) ของเป้าหมาย รองรับการค้นหาพาร์ทที่ซ่อนอยู่ลึกๆ
local function GetTargetCFrame(instance)
    if instance:IsA("BasePart") then
        return instance.CFrame
    elseif instance:IsA("Model") then
        if instance.PrimaryPart then
            return instance.PrimaryPart.CFrame
        else
            -- ใช้ true เพื่อสแกนหา BasePart ทะลุลงไปในโฟลเดอร์ย่อยๆ
            local firstPart = instance:FindFirstChildWhichIsA("BasePart", true)
            if firstPart then
                return firstPart.CFrame
            end
        end
    end
    return nil
end

-- อัลกอริทึมค้นหาเป้าหมายที่ใกล้ที่สุด (Closest Target Algorithm)
local function GetClosestTarget(folder, hrpPosition, ignoreList)
    local closestInstance = nil
    local shortestDistance = math.huge
    
    if folder then
        for _, child in ipairs(folder:GetChildren()) do
            -- เช็คว่าไม่ได้อยู่ในบัญชีดำ
            if not ignoreList[child] then
                local targetCFrame = GetTargetCFrame(child)
                if targetCFrame then
                    local distance = (hrpPosition - targetCFrame.Position).Magnitude
                    if distance < shortestDistance then
                        shortestDistance = distance
                        closestInstance = child
                    end
                end
            end
        end
    end
    
    return closestInstance
end

-- Thread 1: Loop การทำงานหลักสำหรับ Auto Farm Coin
task.spawn(function()
    while true do
        task.wait() 
        
        -- ทำงานเฉพาะตอนเปิดโหมดเหรียญ และไม่ได้เปิดโหมดฟาร์มตัวทับกัน
        if AutoCoinEnabled and not AutoNoobiesEnabled then
            pcall(function()
                local character = LocalPlayer.Character
                if not character then return end
                
                local hrp = character:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                
                local coinsFolder = Workspace:FindFirstChild("Coins")
                local closestCoin = GetClosestTarget(coinsFolder, hrp.Position, ignoreCoins)
                
                if closestCoin then
                    local targetCFrame = GetTargetCFrame(closestCoin)
                    
                    if UseWarpMode then
                        -- [ โหมดวาร์ป ]
                        hrp.CFrame = targetCFrame
                        hrp.Velocity = Vector3.new(0, 0, 0)
                        hrp.RotVelocity = Vector3.new(0, 0, 0)
                        
                        ignoreCoins[closestCoin] = true -- บันทึกลงบัญชีดำ
                        task.wait(0.05) -- ดีเลย์เซิร์ฟเวอร์เล็กน้อย
                    else
                        -- [ โหมดบินเนียน ]
                        local distance = (hrp.Position - targetCFrame.Position).Magnitude
                        local timeToReach = distance / TweenSpeed
                        
                        if timeToReach < 0.05 then timeToReach = 0.05 end 
                        
                        local tweenInfo = TweenInfo.new(timeToReach, Enum.EasingStyle.Linear)
                        currentTween = TweenService:Create(hrp, tweenInfo, {CFrame = targetCFrame})
                        currentTween:Play()
                        
                        local isCompleted = false
                        local connection
                        connection = currentTween.Completed:Connect(function()
                            isCompleted = true
                        end)
                        
                        -- ล็อคความเร็วการตกของตัวละครขณะบิน
                        while not isCompleted and AutoCoinEnabled and not AutoNoobiesEnabled do
                            task.wait()
                            hrp.Velocity = Vector3.new(0, 0, 0)
                            hrp.RotVelocity = Vector3.new(0, 0, 0)
                        end
                        
                        if connection then connection:Disconnect() end
                        if currentTween then currentTween:Cancel() end
                        
                        ignoreCoins[closestCoin] = true -- บันทึกลงบัญชีดำ
                        task.wait(0.05)
                    end
                else
                    -- ถ้าหาเหรียญไม่เจอ (หรือเก็บหมดแมพแล้ว) ให้รอไปก่อน
                    task.wait(0.5)
                end
            end)
        end
    end
end)

